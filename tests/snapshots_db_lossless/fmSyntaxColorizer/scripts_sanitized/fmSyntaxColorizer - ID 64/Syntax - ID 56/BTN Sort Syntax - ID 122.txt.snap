# 20140429 MrW With [SHIFT]+[CTRL]+[ALT] Renumber and hard sort
# 20121102 MrW 


Variable setzen [ $HardSort ; _IsKeyALT UND _IsKeySHIFT UND _IsKeyCTRL ]

Wenn [ _IsKeyALT ]
	Script ausführen [ "Renumber ALL Syntax" ; Specified: Aus Liste ; Parameter: ]
	
	Wenn [ $HardSort ]
		Script ausführen [ "Hard sort Syntax" ; Specified: Aus Liste ; Parameter: ]
	Ende (wenn)
	
Sonst
	Script ausführen [ "Sort Syntax" ; Specified: Aus Liste ; Parameter: ]
	
Ende (wenn)
