				<LayoutObject hash="6F7B7E143242238B6CEAC1CEC6A9B8E8" id="91" type="Text" name="" kind="2">
					<UUID>F798FC3F-CC37-4D31-8221-8385C9971BD0</UUID>
					<Bounds top="189" left="10" bottom="300" right="1384"></Bounds>
					<Options>805306368</Options>
					<Text>
						<Options>2</Options>
						<StyledText>
							<Data><![CDATA[This file endeavors to have an example of one of everything (Ooe), i.e. one of every possible configuration of a solution element.
e.g. every kind of layout part or layout object, every kind of value list, every kind of script step, etc.
Achieving this 100% is not a realistic goal, but the hope is that over time we can add examples of all these different permutations in this file.

This file was last updated on 2025-06-09. Please update the Change Log script when you add something to this file.]]></Data>
						</StyledText>
					</Text>
					<LocalCSS type="ThemeCustomStyle" name="FM-413A4E13-09BF-4799-B66D-27BE078F05E7" displayName="MyCustomStyleInApexBlue"><![CDATA[self.FM-413A4E13-09BF-4799-B66D-27BE078F05E7:normal .self
{
	background-image: none;
	background-color: rgba(99.9456%,98.6359%,25.3202%,1);
	border-image-source: none;
}
]]></LocalCSS>
				</LayoutObject>
