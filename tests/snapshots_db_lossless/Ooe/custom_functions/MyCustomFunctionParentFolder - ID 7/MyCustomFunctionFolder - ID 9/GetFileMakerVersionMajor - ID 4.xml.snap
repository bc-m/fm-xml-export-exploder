<CustomFunction id="4" name="GetFileMakerVersionMajor" access="All">
	<UUID modifications="1" userName="Mislav" accountName="Admin" timestamp="2025-06-08T15:22:25">B346B342-C393-4502-A4CE-BADBFE5BA1C2</UUID>
	<TagList></TagList>
	<Calculation>
		<Text><![CDATA[// Signature:
// GetFileMakerVersionMajor

// Purpose:
// Detects major component of current FileMaker application version

// Parameters:
// None

// Result:
// Returns major component of current FileMaker application version
// For example, if FileMaker application version is 19.2.1, this custom function will return 19

// Dependencies:
// None

// History:
// Created: Mislav Kos <mkos@soliantconsulting.com>


GetAsNumber ( GetValue ( Substitute ( RightWords ( Get ( ApplicationVersion ) ; 1 ) ; "." ; ¶ ) ; 1 ) )]]></Text>
	</Calculation>
	<Display>GetFileMakerVersionMajor</Display>
</CustomFunction>
