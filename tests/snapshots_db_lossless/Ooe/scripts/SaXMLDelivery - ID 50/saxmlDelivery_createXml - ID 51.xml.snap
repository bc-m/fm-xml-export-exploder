		<Step hash="7F887E603C907CE3FC1E8AFD51E7D153" index="75" id="89" name="# (comment)" enable="True">
			<UUID>C9B403BF-3E8B-4876-B219-E52ACB7496E6</UUID>
			<SourceUUID>26E0054A-9A84-4926-9EF1-A50B174B9B0D</SourceUUID>
			<Options>4</Options>
			<ParameterValues membercount="1">
				<Parameter type="Comment">
					<Comment value="Load optional param includeDetailsForAnalysisTools param into local variable"></Comment>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="9ED2D06CEDF2EA93541208965591F512" index="76" id="141" name="Set Variable" enable="True">
			<UUID>CDC94019-5335-4EA3-BC94-1F75A6926781</UUID>
			<SourceUUID>E26C097F-6A19-44DB-A9F5-9B395A546434</SourceUUID>
			<Options>16388</Options>
			<ParameterValues membercount="1">
				<Parameter type="Variable">
					<value>
						<Calculation datatype="1" position="1">
							<Calculation>
								<Text><![CDATA[Let ( [ 
	includeDetailsForAnalysisTools = JSONGetElement ( Get ( ScriptParameter ) ; "includeDetailsForAnalysisTools" ) ; 

	// isUndefined will be true if includeDetailsForAnalysisTools was not specified in the parameter (or the parameter is not valid json)
	isUndefined = IsEmpty ( includeDetailsForAnalysisTools ) or Left ( includeDetailsForAnalysisTools ; 3 ) = "? *" ; 

	split = Substitute ( RightWords ( Get ( ApplicationVersion ) ; 1 ) ; "." ; ¶ ) ; 
	majorFileMakerVersion = GetAsNumber ( GetValue ( split ; 1 ) ) ; 
	minorFileMakerVersion = GetAsNumber ( GetValue ( split ; 2 ) ) ; 

	// "Include details for analysis tools" became available in FM 21.1
	isSupported = $majorFileMakerVersion > 21 or ( $majorFileMakerVersion = 21 and $minorFileMakerVersion ≥ 1 )

] ; 
	Case ( 
		isUndefined ; // if includeDetailsForAnalysisTools wasn't specified in the parameter
		isSupported ; // default to true, but only if the fm version supports it
		not isSupported ; // otherwise, if it's not a supported feature
		False ; // default to false
		includeDetailsForAnalysisTools // if it was specified in the parameter, and it's a supported feature, use the value from the parameter
	)
)]]></Text>
							</Calculation>
						</Calculation>
					</value>
					<Name value="$_includeDetailsForAnalysisTools"></Name>
					<repetition>
						<Calculation datatype="1" position="2">
							<Calculation>
								<Text><![CDATA[1]]></Text>
							</Calculation>
						</Calculation>
					</repetition>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="B70DFA934310B903FA254DA0F59E0473" index="77" id="89" name="# (comment)" enable="True">
			<UUID>C945C375-2450-43FE-B50D-680DE1C92179</UUID>
