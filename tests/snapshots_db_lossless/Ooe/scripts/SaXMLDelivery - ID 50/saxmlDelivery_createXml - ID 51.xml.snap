			<SourceUUID>DE72CE36-6A92-42DD-B066-CEE893AF1CF0</SourceUUID>
			<Options>16388</Options>
			<ParameterValues membercount="1">
				<Parameter type="Variable">
					<value>
						<Calculation datatype="1" position="1">
							<Calculation>
								<Text><![CDATA[Get ( AccountPrivilegeSetName ) = "[Full Access]" or not IsEmpty ( FilterValues ( Get ( AccountExtendedPrivileges ) ; "fmrest" ) )]]></Text>
							</Calculation>
						</Calculation>
					</value>
					<Name value="$allowedPrivilegeSet"></Name>
					<repetition></repetition>
				</Parameter>
			</ParameterValues>
		</Step>
