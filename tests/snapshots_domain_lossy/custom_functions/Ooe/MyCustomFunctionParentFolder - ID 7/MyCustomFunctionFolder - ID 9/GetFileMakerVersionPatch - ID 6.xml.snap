<CustomFunction id="6" name="GetFileMakerVersionPatch" access="All">
	<UUID modifications="1" userName="Mislav" accountName="Admin" timestamp="2025-06-08T15:22:25">6F60EA66-06F1-43FA-807C-CC0C9A5E44D2</UUID>
	<Calculation>
		<Text><![CDATA[// Signature:
// GetFileMakerVersionPatch

// Purpose:
// Detects patch component of current FileMaker application version

// Parameters:
// None

// Result:
// Returns patch component of current FileMaker application version
// For example, if FileMaker application version is 19.2.1, this custom function will return 1

// Dependencies:
// None

// History:
// Created: Mislav Kos <mkos@soliantconsulting.com>


GetAsNumber ( GetValue ( Substitute ( RightWords ( Get ( ApplicationVersion ) ; 1 ) ; "." ; ¶ ) ; 3 ) )]]></Text>
	</Calculation>
	<Display>GetFileMakerVersionPatch</Display>
</CustomFunction>
