					<Calculation datatype="7" position="0">
						<Calculation>
							<Text><![CDATA[$gitService = "GitHub" and $errorCode = 10 and not $isErrorResponseStatusCode]]></Text>
						</Calculation>
					</Calculation>
				</Parameter>
			</ParameterValues>
		</Step>
