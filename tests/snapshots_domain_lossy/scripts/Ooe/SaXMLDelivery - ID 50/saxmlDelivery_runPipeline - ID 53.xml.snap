		<Step hash="4487B75CF3559ECADF83B39BD0DB91D5" id="141" name="Set Variable" enable="True">
			<SourceUUID>B3B8BE6C-22ED-4536-BD95-950EB8B81FEF</SourceUUID>
			<Options>16388</Options>
			<ParameterValues membercount="1">
				<Parameter type="Variable">
					<value>
						<Calculation datatype="1" position="1">
							<Calculation>
								<Text><![CDATA[// We would typically use a custom function here, but we wanted this script to have as few dependencies as possible
// Signature:
// GetHttpResponseStatusCode ( responseHeaders )
// Purpose:
// Return the last status code from the response headers
// See https://en.wikipedia.org/wiki/List_of_HTTP_status_codes
// For example, if the last status line was "HTTP/1.1 200 OK", this function will return 200
// Parameters:
// responseHeaders
// Result:
// Response status code
// Dependencies:
// None
// History:
// Mislav Kos <mkos@soliantconsulting.com>: Created custom function.

Let ( [ 
	responseHeaders = $responseHeaders ; 

	searchString = "HTTP/1.1 " ; 
	searchStringCount = PatternCount ( responseHeaders ; searchString ) ; 
	start = Position ( responseHeaders ; searchString ; 1 ; searchStringCount ) ; 
	start = start + If ( start > 0 ; Length ( searchString ) ) ; 
	end = Position ( responseHeaders ; ¶ ; start ; 1 ) ; 
	end = If ( end > 0 ; end ; Length ( responseHeaders ) + 1 ) ; 
	numberOfCharacters = end - start ; 
	codeWithMessage = Middle ( responseHeaders ; start ; numberOfCharacters ) ; 
	code = LeftWords ( codeWithMessage ; 1 ) ; 
	~ = ""
] ; 
	GetAsNumber ( code )
)]]></Text>
							</Calculation>
						</Calculation>
					</value>
					<Name value="$responseStatusCode"></Name>
					<repetition>
						<Calculation datatype="1" position="2">
							<Calculation>
								<Text><![CDATA[1]]></Text>
							</Calculation>
						</Calculation>
					</repetition>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="742F3A416F6AC199E1582DE2BCF5D9D2" id="141" name="Set Variable" enable="True">
			<SourceUUID>86AE3C8B-9C59-486D-B645-3B9993AC7868</SourceUUID>
			<Options>16388</Options>
			<ParameterValues membercount="1">
				<Parameter type="Variable">
					<value>
						<Calculation datatype="1" position="1">
							<Calculation>
								<Text><![CDATA[not IsEmpty ( $responseStatusCode ) and ( $responseStatusCode < 200 or $responseStatusCode > 299 )]]></Text>
							</Calculation>
						</Calculation>
					</value>
					<Name value="$isErrorResponseStatusCode"></Name>
					<repetition>
						<Calculation datatype="1" position="2">
							<Calculation>
								<Text><![CDATA[1]]></Text>
							</Calculation>
						</Calculation>
					</repetition>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="436E6D08278FE5956F6D63FBD2EF3944" id="68" name="If" enable="True">
