					<Comment value="■■■■■■■■■■ CONFIGURATION STEP (optional): Customize restrictions to run this script"></Comment>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="860F592D86A3579DCFFC96D1C12E68C9" id="141" name="Set Variable" enable="True">
			<SourceUUID>DE72CE36-6A92-42DD-B066-CEE893AF1CF0</SourceUUID>
			<Options>16388</Options>
			<ParameterValues membercount="1">
				<Parameter type="Variable">
					<value>
						<Calculation datatype="1" position="1">
							<Calculation>
								<Text><![CDATA[Get ( AccountPrivilegeSetName ) = "[Full Access]" or not IsEmpty ( FilterValues ( Get ( AccountExtendedPrivileges ) ; "fmrest" ) )]]></Text>
							</Calculation>
						</Calculation>
					</value>
					<Name value="$allowedPrivilegeSet"></Name>
					<repetition></repetition>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="3F9CF775DA7B7342AA502826E4A75E7D" id="68" name="If" enable="True">
			<SourceUUID>1D4360D5-557D-4CAC-81B3-1F6BB754261E</SourceUUID>
			<Options>16384</Options>
