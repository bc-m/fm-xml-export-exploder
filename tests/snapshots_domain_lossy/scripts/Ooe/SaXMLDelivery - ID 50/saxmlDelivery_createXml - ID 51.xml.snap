				</Parameter>
				<Parameter type="Calculation">
					<Calculation datatype="7" position="0">
						<Calculation>
							<Text><![CDATA[not IsEmpty ( $message )
and PatternCount ( Get ( ApplicationVersion ) ; "Data API Engine" ) = 0
and PatternCount ( Get ( ApplicationVersion ) ; "Server" ) = 0]]></Text>
						</Calculation>
					</Calculation>
				</Parameter>
			</ParameterValues>
		</Step>
