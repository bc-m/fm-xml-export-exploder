			</ParameterValues>
		</Step>
		<Step hash="6449DBD4866D83F9D9F8FAE8A5FA0399" id="141" name="Set Variable" enable="True">
			<SourceUUID>51174892-4C55-4967-B938-8E5735C18E5C</SourceUUID>
			<Options>16388</Options>
			<ParameterValues membercount="1">
				<Parameter type="Variable">
					<value>
						<Calculation datatype="1" position="1">
							<Calculation>
								<Text><![CDATA[JSONSetElement ( "" ; [ "errorCode" ; $errorCode ; JSONNumber ] ; [ "message" ; $message ; JSONString ] ; [ "data" ; $data ; JSONObject ] )]]></Text>
							</Calculation>
						</Calculation>
					</value>
					<Name value="$result"></Name>
					<repetition>
						<Calculation datatype="1" position="2">
							<Calculation>
								<Text><![CDATA[1]]></Text>
							</Calculation>
						</Calculation>
					</repetition>
				</Parameter>
			</ParameterValues>
		</Step>
