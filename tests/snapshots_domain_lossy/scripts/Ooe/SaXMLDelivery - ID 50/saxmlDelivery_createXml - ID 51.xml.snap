		<Step hash="1A0830763AE2D7472B5927FC0A38431F" id="89" name="# (comment)" enable="True">
			<SourceUUID>E174F929-AEEA-43F9-AF00-896705076DC9</SourceUUID>
			<Options>4</Options>
			<ParameterValues membercount="1">
				<Parameter type="Comment">
					<Comment value="Delete records older than 3 months"></Comment>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="1C07A17782A3D7A31149441869426EAA" id="141" name="Set Variable" enable="True">
			<SourceUUID>FC1810EC-1C86-4C92-9D7E-50D6B11D88C0</SourceUUID>
			<Options>16388</Options>
			<ParameterValues membercount="1">
				<Parameter type="Variable">
					<value>
						<Calculation datatype="1" position="1">
							<Calculation>
								<Text><![CDATA[Let ( 
	today = Get ( CurrentDate ) ; 
	Date ( Month ( today ) - 3 ; Day ( today ) ; Year ( today ) ) 
)]]></Text>
							</Calculation>
						</Calculation>
					</value>
					<Name value="$purgeDate"></Name>
					<repetition>
						<Calculation datatype="1" position="2">
							<Calculation>
								<Text><![CDATA[1]]></Text>
							</Calculation>
						</Calculation>
					</repetition>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="7B38DB6874B4EEAE61EF9085B1F11A04" id="22" name="Enter Find Mode" enable="True">
