								<Calculation>
									<Text><![CDATA[1]]></Text>
								</Calculation>
							</Calculation>
						</repetition>
						<TableOccurrenceReference id="1065099" name="SaXMLDelivery"></TableOccurrenceReference>
					</FieldReference>
				</Parameter>
				<Parameter type="Calculation">
					<Calculation datatype="1" position="0">
						<Calculation>
							<Text><![CDATA[Get ( ScriptName ) & " script result:¶" & JSONFormatElements ( $result )]]></Text>
						</Calculation>
					</Calculation>
				</Parameter>
			</ParameterValues>
