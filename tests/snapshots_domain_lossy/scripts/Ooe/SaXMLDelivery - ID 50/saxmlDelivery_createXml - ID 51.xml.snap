					</Calculation>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="F0DB5A099DD73E4813160228EE326139" id="68" name="If" enable="True">
			<SourceUUID>EB414DD7-4D12-4345-A241-30A27C29FE53</SourceUUID>
			<Options>16384</Options>
			<ParameterValues membercount="2">
				<Parameter type="Boolean">
					<Boolean type="Collapsed" id="33554432" value="False"></Boolean>
				</Parameter>
				<Parameter type="Calculation">
					<Calculation datatype="7" position="0">
						<Calculation>
							<Text><![CDATA[Get ( LayoutTableName ) = GetValue ( Substitute ( GetFieldName ( SaXMLDelivery::xmlFile ) ; "::" ; ¶ ) ; 1 ) and not IsEmpty ( $recordId )]]></Text>
						</Calculation>
					</Calculation>
				</Parameter>
			</ParameterValues>
		</Step>
