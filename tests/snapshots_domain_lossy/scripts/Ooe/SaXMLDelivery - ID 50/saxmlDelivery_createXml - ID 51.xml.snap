			<ParameterValues membercount="1">
				<Parameter type="Variable">
					<value>
						<Calculation datatype="1" position="1">
							<Calculation>
								<Text><![CDATA[JSONSetElement ( $data 
	; [ "recordId" ; $recordId ; JSONString ] 
	; [ "xmlFieldName" ; GetFieldName ( SaXMLDelivery::xmlFile ) ; JSONString ] 
	; [ "timeToCreate" ; $timeToCreate ; JSONString ] 
	; [ "timeToUpload" ; $timeToUpload ; JSONString ] 
	; [ "addonVersion" ; $addonVersion ; JSONString ] 
)]]></Text>
							</Calculation>
						</Calculation>
					</value>
					<Name value="$data"></Name>
