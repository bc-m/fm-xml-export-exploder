					<Calculation datatype="1" position="0">
						<Calculation>
							<Text><![CDATA[JSONSetElement ( "" ; [ "errorCode" ; 9 ; JSONNumber ] ; [ "message" ; "Insufficient privileges" ; JSONString ] )]]></Text>
						</Calculation>
					</Calculation>
				</Parameter>
			</ParameterValues>
		</Step>
		<Step hash="8BE33BF5BBBF82DF820160A7E9E06B78" id="70" name="End If" enable="True">
			<SourceUUID>3C235744-069E-4E7D-8050-857C01187107</SourceUUID>
