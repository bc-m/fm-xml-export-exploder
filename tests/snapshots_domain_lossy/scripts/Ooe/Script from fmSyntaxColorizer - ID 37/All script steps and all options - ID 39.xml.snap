		<Step hash="62E6080A359BAF9F047966BEA4FCE679" id="141" name="Set Variable" enable="True">
			<Options>16388</Options>
			<ParameterValues membercount="1">
				<Parameter type="Variable">
					<value>
						<Calculation datatype="1" position="1">
							<Calculation>
								<Text><![CDATA[/*Let([ 
$Command_EN =_Syntax::Command_EN ;
$Command_Foreign = Syntax.GUISyntax::Command ;
$CommandColoringOn = _Syntax::On = 1;
$ColorExists = Syntax.Color::__ID > 0 and Syntax.Color::ColorName ≠ "--None--";
$ColorHex = Syntax.Color::_kColorHex ;
vStamp = Get( CurrentTime )
];
Case( 

_Syntax::_kIsGroupTitle ; "" ;

not $CommandColoringOn or not $ColorExists ;
vStamp & " Removed: English " & MBS( "SyntaxColoring.RemoveTag" ; $Command_EN ) & 
Case( _Syntax::_gLanguage <> "English" and not IsEmpty( $Command_Foreign ) ;
  ", " & _Syntax::_gLanguage & " " & MBS( "SyntaxColoring.RemoveTag" ; $Command_Foreign )
) ;

$CommandColoringOn and $ColorExists ;
vStamp & " Added: English " & MBS( "SyntaxColoring.AddTag" ; $Command_EN ; $ColorHex ) & 
Case( _Syntax::_gLanguage ≠ "English" and not IsEmpty( $Command_Foreign ) ;
  ", " & _Syntax::_gLanguage & " " & MBS( "SyntaxColoring.AddTag" ; $Command_Foreign ; $ColorHex )
) ;

"-"

))*/]]></Text>
							</Calculation>
						</Calculation>
					</value>
					<Name value="$MBS_Command_Results"></Name>
					<repetition>
						<Calculation datatype="1" position="2">
							<Calculation>
								<Text><![CDATA[1]]></Text>
							</Calculation>
						</Calculation>
					</repetition>
				</Parameter>
			</ParameterValues>
		</Step>
