# ====================================================================================================
# DESCRIPTION: 
# Generate a SaXML file and store it in a container field
# The context upon exit will be a SaXML layout with a record that has the xml file
# This script is intended to be run via the Data API by a Bitbucket pipeline or a GitHub action; see https://bitbucket.org/soliantconsulting/saxml-delivery/src/main/
# It can also be run directly by a full access user

# PARAMETER:
# JSONSetElement ( "" 
  	; [ "includeDetailsForAnalysisTools" ; True ; JSONBoolean ] // optional; defaults to true for supported versions of FileMaker, i.e. ≥21.1
  )

# RESULT:			
# { errorCode, message, data { recordId, xmlFieldName, timeToCreate, timeToUpload, addonVersion } }

# CONTEXT:
# Any

# DEPENDENCIES:
# The presence of the following solution elements in this database file:
# "SaXMLDelivery" table
# "SaXMLDeliveryExecutionContext" layout

# NOTES:
# There are a few places where custom functions would typically be used, but those were replaced with the bodies of those custom functions to maximize the portability of this script

# HISTORY:
# CLARIS-88 5/2/24 mkos: Created script based on bengert's POC script
# 2024-10-07 mkos: Added includeDetailsForAnalysisTools param
# 2025-08-29 mkos: Delete xml file in temp folder after it's uploaded to the container field
# 2025-08-30 mkos: Added addonVersion to script result
# ====================================================================================================

# ■■■■■■■■■■ Add-on version
Set Variable [ $addonVersion[1] ; "0.1.9" ]

# •  •  •  •  •  •  •  •  •  •  •  •  •  •  •  •  •  •  •  •
# CAUTION: This script runs with FULL ACCESS privileges
# This is needed, because the Save as XML script step requires full access
# https://help.claris.com/en/pro-help/content/save-a-copy-as-xml.html
# •  •  •  •  •  •  •  •  •  •  •  •  •  •  •  •  •  •  •  •

Allow User Abort [ OFF ]

# Initialize vars
Set Variable [ $errorCode ; 0 ]
Set Variable [ $message ; "" ]
Set Variable [ $data ; "{}" ]

# Send script to server via PSoS
If [ PatternCount ( Get ( ApplicationVersion ) ; "Server" ) = 0 // if not already running on fmse ]
	# Only try to do this if file is hosted
	If [ Get ( ConnectionState ) ≠ 0 ]
		Perform Script on Server [ By name ; ⚠️ PARAMETER "Parameter" NOT PARSED ⚠️ ; Wait for completion: ON ]
		Set Variable [ $errorCode ; Get ( LastError ) ]
		Set Variable [ $recordId ; JSONGetElement ( Get ( ScriptResult ) ; "data.recordId" ) ]
		If [ $errorCode = 0 and not IsEmpty ( $recordId ) ]
			Enter Find Mode [ Pause: OFF ]
			Go to Layout [ Layout: "SaXMLDeliveryExecutionContext" ; Animation: None ]
			Set Field [ SaXMLDelivery::recordId ; $recordId ]
			Perform Find
		Else
			Go to Layout [ Layout: "SaXMLDeliveryExecutionContext" ; Animation: None ]
			Show All Records
			Show Omitted Only
		End If
		Exit Script [ Get ( ScriptResult ) ]
	End If
End If

# Validate privilege set - must be full access or must have access via the Data API
# ■■■■■■■■■■ CONFIGURATION STEP (optional): Customize restrictions to run this script
Set Variable [ $allowedPrivilegeSet ; Get ( AccountPrivilegeSetName ) = "[Full Access]" or not IsEmpty ( FilterValues ( Get ( AccountExtendedPrivileges ) ; "fmrest" ) ) ]
If [ not $allowedPrivilegeSet ]
	Exit Script [ JSONSetElement ( "" ; [ "errorCode" ; 9 ; JSONNumber ] ; [ "message" ; "Insufficient privileges" ; JSONString ] ) ]
End If

# Load optional param includeDetailsForAnalysisTools param into local variable
Set Variable [ $_includeDetailsForAnalysisTools[1] ; Let ( [ 
	includeDetailsForAnalysisTools = JSONGetElement ( Get ( ScriptParameter ) ; "includeDetailsForAnalysisTools" ) ; 

	// isUndefined will be true if includeDetailsForAnalysisTools was not specified in the parameter (or the parameter is not valid json)
	isUndefined = IsEmpty ( includeDetailsForAnalysisTools ) or Left ( includeDetailsForAnalysisTools ; 3 ) = "? *" ; 

	split = Substitute ( RightWords ( Get ( ApplicationVersion ) ; 1 ) ; "." ; ¶ ) ; 
	majorFileMakerVersion = GetAsNumber ( GetValue ( split ; 1 ) ) ; 
	minorFileMakerVersion = GetAsNumber ( GetValue ( split ; 2 ) ) ; 

	// "Include details for analysis tools" became available in FM 21.1
	isSupported = $majorFileMakerVersion > 21 or ( $majorFileMakerVersion = 21 and $minorFileMakerVersion ≥ 1 )

] ; 
	Case ( 
		isUndefined ; // if includeDetailsForAnalysisTools wasn't specified in the parameter
		isSupported ; // default to true, but only if the fm version supports it
		not isSupported ; // otherwise, if it's not a supported feature
		False ; // default to false
		includeDetailsForAnalysisTools // if it was specified in the parameter, and it's a supported feature, use the value from the parameter
	)
) ]

# Remember parent script's error capture state
Set Variable [ $parentScriptErrorCaptureState ; Get ( ErrorCaptureState ) ]
Set Error Capture [ ON ]

# ====================================================================================================
# PROCESS
# ====================================================================================================

# Set up context
If [ $errorCode = 0 ]
	Go to Layout [ Layout: "SaXMLDeliveryExecutionContext" ; Animation: None ]
	Set Variable [ $errorCode ; Get ( LastError ) ]
End If

# Purge old records
If [ $errorCode = 0 ]
	# Delete records older than 3 months
	Set Variable [ $purgeDate[1] ; Let ( 
	today = Get ( CurrentDate ) ; 
	Date ( Month ( today ) - 3 ; Day ( today ) ; Year ( today ) ) 
) ]
	Enter Find Mode [ Pause: OFF ]
	Set Field [ SaXMLDelivery::createTimestamp ; "<" & $purgeDate ]
	Perform Find
	If [ Get ( FoundCount ) > 0 and Get ( LayoutTableName ) = GetValue ( Substitute ( GetFieldName ( SaXMLDelivery::xmlFile ) ; "::" ; ¶ ) ; 1 ) // belt and suspenders ]
		Delete All Records [ With dialog: OFF ]
	End If
End If

# Create new record
If [ $errorCode = 0 ]
	New Record/Request
	Set Variable [ $errorCode ; Get ( LastError ) ]
End If

# Create SaXML xml file on file system
# 2024-10-07 mkos: Added support for $_includeDetailsForAnalysisTools
If [ $errorCode = 0 ]
	Set Variable [ $xmlPath ; Get ( TemporaryPath ) & Get ( FileName ) & ".xml" ]
	Set Variable [ $start ; Get ( CurrentTimeUTCMilliseconds ) ]
	If [ $_includeDetailsForAnalysisTools ]
		Save a Copy as XML [ Get ( WindowName ) ; ⚠️ PARAMETER "UniversalPathList" NOT PARSED ⚠️ ; Include details for analysis tools: ON ; Save each layout object&apos;s binary data under its node: OFF ]
	Else
		Save a Copy as XML [ Get ( WindowName ) ; ⚠️ PARAMETER "UniversalPathList" NOT PARSED ⚠️ ; Include details for analysis tools: OFF ; Save each layout object&apos;s binary data under its node: OFF ]
	End If
	Set Variable [ $errorCode ; Get ( LastError ) ]
	Set Variable [ $timeToCreate[1] ; GetAsTime ( ( Get ( CurrentTimeUTCMilliseconds ) - $start ) / 1000 ) ]
End If

# Upload xml file to container field
# Note, we tried using the Read From Data File step, but it's not any faster, and it makes the code more complex, bc you have to read the file in chunks
# 2024-07-17 mkos: Don't automatically encode url since ConvertFromFileMakerPath will already do that for us
If [ $errorCode = 0 ]
	Set Variable [ $start ; Get ( CurrentTimeUTCMilliseconds ) ]
	Insert from URL [ Verify SSL Certificates: OFF ; Select: ON ; With dialog: OFF ; Target: SaXMLDelivery::xmlFile ; ⚠️ PARAMETER "URL" NOT PARSED ⚠️ ]
	Set Variable [ $errorCode ; Get ( LastError ) ]
	Set Variable [ $timeToUpload[1] ; GetAsTime ( ( Get ( CurrentTimeUTCMilliseconds ) - $start ) / 1000 ) ]
End If
If [ $errorCode = 0 ]
	Set Field [ SaXMLDelivery::timeToCreate ; $timeToCreate ]
	Set Field [ SaXMLDelivery::timeToUpload ; $timeToUpload ]
	Set Field [ SaXMLDelivery::sizeInBytes ; GetContainerAttribute ( SaXMLDelivery::xmlFile ; "filesize" ) ]
	Commit Records/Requests [ Skip data entry validation ; With dialog: OFF ]
	Set Variable [ $errorCode ; Get ( LastError ) ]
	Set Variable [ $recordId ; SaXMLDelivery::recordId ]
End If

# Delete xml file in temp folder
If [ $errorCode = 0 ]
	Delete File [ ⚠️ PARAMETER "UniversalPathList" NOT PARSED ⚠️ ]
	Set Variable [ $errorCode ; Get ( LastError ) ]
End If

# Handle error
If [ $errorCode > 1 and IsEmpty ( $message ) ]
	Set Variable [ $message[1] ; // We would typically use a custom function here, but we wanted this script to have as few dependencies as possible
/**
 * @SIGNATURE:
 * ErrorMessage ( errorCode )
 * 
 * @PARAMETERS:
 * errorCode	:	Number corresponding to the error code. For example, from Get ( LastError ).
 * 
 * @HISTORY:
 *     Created	:	yyyy-MMM-dd by Jeremiah Small (?) , Soliant Consulting
 * 			  	posted on http://www.briandunning.com/cf/124
 *    Modified	:	2011-08-07 by Mislav Kos, Soliant Consulting
 *    Modified	:	2017-12-16 by Mislav Kos, Soliant Consulting - now current through FileMaker 16
 *    Modified	:	2022-10-17 by Mislav Kos, Soliant Consulting - now current through FileMaker 19.5
 * 
 * @PURPOSE:
 * Return error descriptions for codes from FileMaker help text (see https://help.claris.com/en/pro-help/content/error-codes.html)
 * 
 * @RESULT:
 * Error description text.
 * 
 * @ERRORS:
 * N/A
 */

Let ( [  
		errorCode = $errorCode ; 
		errorMessage = Case (
			errorCode =   -1 ; 			"Unknown error" ; 
			errorCode =   0 ; 			"No error" ; 
			errorCode =   1 ; 			"User canceled action" ; 
			errorCode =   2 ; 			"Memory error" ; 
			errorCode =   3 ; 			"Command is unavailable (for example, wrong operating system or mode)" ; 
			errorCode =   4 ; 			"Command is unknown" ; 
			errorCode =   5 ; 			"Command is invalid (for example, a Set Field script step does not have a calculation specified)" ; 
			errorCode =   6 ; 			"File is read-only" ; 
			errorCode =   7 ; 			"Running out of memory" ; 
			errorCode =   9 ; 			"Insufficient privileges" ; 
			errorCode =   10 ; 			"Requested data is missing" ; 
			errorCode =   11 ; 			"Name is not valid" ; 
			errorCode =   12 ; 			"Name already exists" ; 
			errorCode =   13 ; 			"File or object is in use" ; 
			errorCode =   14 ; 			"Out of range" ; 
			errorCode =   15 ; 			"Can't divide by zero" ; 
			errorCode =   16 ; 			"Operation failed; request retry (for example, a user query)" ; 
			errorCode =   17 ; 			"Attempt to convert foreign character set to UTF-16 failed" ; 
			errorCode =   18 ; 			"Client must provide account information to proceed" ; 
			errorCode =   19 ; 			"String contains characters other than A-Z, a-z, 0-9 (ASCII)" ; 
			errorCode =   20 ; 			"Command/operation canceled by triggered script" ; 
			errorCode =   21 ; 			"Request not supported (for example, when creating a hard link on a file system that does not support hard links)" ; 
			errorCode =   100 ; 			"File is missing" ; 
			errorCode =   101 ; 			"Record is missing" ; 
			errorCode =   102 ; 			"Field is missing" ; 
			errorCode =   103 ; 			"Relationship is missing" ; 
			errorCode =   104 ; 			"Script is missing" ; 
			errorCode =   105 ; 			"Layout is missing" ; 
			errorCode =   106 ; 			"Table is missing" ; 
			errorCode =   107 ; 			"Index is missing" ; 
			errorCode =   108 ; 			"Value list is missing" ; 
			errorCode =   109 ; 			"Privilege set is missing" ; 
			errorCode =   110 ; 			"Related tables are missing" ; 
			errorCode =   111 ; 			"Field repetition is invalid" ; 
			errorCode =   112 ; 			"Window is missing" ; 
			errorCode =   113 ; 			"Function is missing" ; 
			errorCode =   114 ; 			"File reference is missing" ; 
			errorCode =   115 ; 			"Menu set is missing" ; 
			errorCode =   116 ; 			"Layout object is missing" ; 
