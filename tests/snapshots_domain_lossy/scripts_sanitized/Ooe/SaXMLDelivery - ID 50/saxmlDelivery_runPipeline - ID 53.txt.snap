# ====================================================================================================
# DESCRIPTION: 
# Trigger a BitBucket pipeline or GitHub run

# PARAMETER:
# JSONSetElement ( "" 
  	; [ "silent" ; True ; JSONBoolean ] // optional; defaults to false
  )

# RESULT:			
# { errorCode, message, data }
# if $gitService = "Bitbucket", data = { buildNumber, createdOn, repoUrl, pipelineBuildUrl }

# CONTEXT:
# Any

# DEPENDENCIES:
# None

# NOTES:
# There are a few places where custom functions would typically be used, but those were replaced with the bodies of those custom functions to maximize the portability of this script

# HISTORY:
# CLARIS-88 6/12/24 mkos: Created script
# 2025-08-29 mkos: Added support for triggering GitHub action to run
# ====================================================================================================

Allow User Abort [ OFF ]

# Initialize vars
Set Variable [ $errorCode ; 0 ]
Set Variable [ $message ; "" ]
Set Variable [ $data ; "{}" ]

# Load optional params 'silent' and 'includeDetailsForAnalysisTools' into local variables
Set Variable [ $_silent[1] ; If ( 
	Left ( JSONGetElement ( Get ( ScriptParameter )  ; "isValidJson" ) ; 3 ) ≠ "? *" ; 
	JSONGetElement ( Get ( ScriptParameter ) ; "silent" )
) ]

# Validate privilege set - must be full access
# ■■■■■■■■■■ CONFIGURATION STEP (optional): Customize restrictions to run this script
If [ Collapsed: OFF ; Get ( AccountPrivilegeSetName ) ≠ "[Full Access]" ]
	Exit Script [ JSONSetElement ( "" ; [ "errorCode" ; 9 ; JSONNumber ] ; [ "message" ; "Insufficient privileges" ; JSONString ] ) ]
End If

# ■■■■■■■■■■ CONFIGURATION STEP: Specify repo name
# For $repoName:
#   Add conditional logic to select correct name depending on which environment the solution is running in
#   For example: If ( GetEnvironment ( "" ) = "prod" ; "amps-prod-saxml-delivery" ; "amps-dev-saxml-delivery" )
Set Variable [ $repoName[1] ; "" ]

# ■■■■■■■■■■ CONFIGURATION STEP: Specify repo api token
# For $accessToken:
#   To set up an access token, go to:
#   Bitbucket → Repository settings → Security → Access tokens → Create repository access token → Create "saxml-delivery" with pipelines 'read' scope
#   GitHub → Settings → Developer settings → Personal access tokens → Create fine-grained token with contents: read & write permissions for the target repository
#   @todo store the access token in a more secure place instead of hard-coding it in this script
Set Variable [ $accessToken[1] ; "" ]

# ■■■■■■■■■■ CONFIGURATION STEP: Specify git account owner, e.g. "soliantconsulting"
Set Variable [ $owner[1] ; "" ]

# ■■■■■■■■■■ CONFIGURATION STEP: Specify git hosting service (supported: "GitHub", "Bitbucket"
Set Variable [ $gitService[1] ; "" ]

# Remember parent script's error capture state
Set Variable [ $parentScriptErrorCaptureState ; Get ( ErrorCaptureState ) ]
Set Error Capture [ ON ]

# ====================================================================================================
# PROCESS
# ====================================================================================================

Set Variable [ $missingRequired[1] ; List ( 
	If ( IsEmpty ( $repoName ) ; "repo name" ) ; 
	If ( IsEmpty ( $accessToken ) ; "access token" ) ; 
	If ( IsEmpty ( $owner ) ; "git account owner" ) ; 
	If ( IsEmpty ( FilterValues ( $gitService ; "Bitbucket¶GitHub" ) ) ; "git hosting service" ) ; 
) ]
If [ Collapsed: OFF ; not IsEmpty ( $missingRequired ) ]
	Set Variable [ $errorCode[1] ; 5 ]
	Set Variable [ $message[1] ; "Missing config: " & Substitute ( $missingRequired ; ¶ ; ", " ) & "." ]
End If

# Confirm action
If [ Collapsed: OFF ; $errorCode = 0 ]
	If [ Collapsed: OFF ; not $_silent ]
		Show Custom Dialog [ Message: "Run " & $repoName & " pipeline?" ; Default Button: "OK" ; Button 2: "Cancel" ]
		If [ Collapsed: OFF ; Get ( LastMessageChoice ) ≠ 1 ]
			Set Variable [ $errorCode[1] ; 1 ]
		End If
	End If
End If

# Prep api call
# 2024-10-07 mkos: @todo add support for an 'includeDetailsForAnalysisTools' parameter by forwarding it to the bitbucket api
If [ Collapsed: OFF ; $errorCode = 0 ]
	If [ Collapsed: OFF ; $gitService = "Bitbucket" ]
		# ref: https://developer.atlassian.com/cloud/bitbucket/rest/api-group-pipelines/#api-repositories-workspace-repo-slug-pipelines-post
		Set Variable [ $url[1] ; "https://api.bitbucket.org/2.0/repositories/" & $owner & "/" & $repoName & "/pipelines" ]
		Set Variable [ $requestBody[1] ; JSONSetElement ( "" 
	; [ "target.ref_type" ; "branch" ; JSONString ]
	; [ "target.type" ; "pipeline_ref_target" ; JSONString ]
	; [ "target.ref_name" ; "main" ; JSONString ] // branch name
	; [ "target.selector.type" ; "custom" ; JSONString ] // pipeline type
	; [ "target.selector.pattern" ; "pull-xml" ; JSONString ] // pipeline name
) ]
		Set Variable [ $curlOptions[1] ;   " --request POST "
& " --url " & $url 
& " --header " & Quote ( "Authorization: Bearer " & $accessToken ) 
& " --header " & Quote ( "Content-Type: application/json" ) 
& " --data @$requestBody"
& " --dump-header $responseHeaders" ]
	Else [ Collapsed: OFF ; Collapsed: OFF ]
		# GitHub
		Set Variable [ $url[1] ; "https://api.github.com/repos/" & $owner & "/" & $repoName & "/dispatches" ]
		Set Variable [ $requestBody[1] ; JSONSetElement ( "" 
	; [ "event_type" ; "saxml-delivery" ; JSONString ] 
) ]
		Set Variable [ $curlOptions[1] ;   " --request POST "
& " --url " & $url 
& " --header " & Quote ( "Authorization: token " & $accessToken ) 
& " --header " & Quote ( "Accept: application/vnd.github.v3+json" ) 
& " --header " & Quote ( "Content-Type: application/json" ) 
& " --data @$requestBody"
& " --dump-header $responseHeaders" ]
	End If
End If

# Make api call to trigger pipeline
If [ Collapsed: OFF ; $errorCode = 0 ]
	Insert from URL [ Verify SSL Certificates: ON ; Select: ON ; With dialog: OFF ; Target: $response ; ⚠️ PARAMETER "URL" NOT PARSED ⚠️ ; $curlOptions ]
	Set Variable [ $errorCode[1] ; Get ( LastError ) ]
	Set Variable [ $responseStatusCode[1] ; // We would typically use a custom function here, but we wanted this script to have as few dependencies as possible
// Signature:
// GetHttpResponseStatusCode ( responseHeaders )
// Purpose:
// Return the last status code from the response headers
// See https://en.wikipedia.org/wiki/List_of_HTTP_status_codes
// For example, if the last status line was "HTTP/1.1 200 OK", this function will return 200
// Parameters:
// responseHeaders
// Result:
// Response status code
// Dependencies:
// None
// History:
// Mislav Kos <mkos@soliantconsulting.com>: Created custom function.

Let ( [ 
	responseHeaders = $responseHeaders ; 

	searchString = "HTTP/1.1 " ; 
	searchStringCount = PatternCount ( responseHeaders ; searchString ) ; 
	start = Position ( responseHeaders ; searchString ; 1 ; searchStringCount ) ; 
	start = start + If ( start > 0 ; Length ( searchString ) ) ; 
	end = Position ( responseHeaders ; ¶ ; start ; 1 ) ; 
	end = If ( end > 0 ; end ; Length ( responseHeaders ) + 1 ) ; 
	numberOfCharacters = end - start ; 
	codeWithMessage = Middle ( responseHeaders ; start ; numberOfCharacters ) ; 
	code = LeftWords ( codeWithMessage ; 1 ) ; 
	~ = ""
] ; 
	GetAsNumber ( code )
) ]
	Set Variable [ $isErrorResponseStatusCode[1] ; not IsEmpty ( $responseStatusCode ) and ( $responseStatusCode < 200 or $responseStatusCode > 299 ) ]
	If [ Collapsed: OFF ; $gitService = "GitHub" and $errorCode = 10 and not $isErrorResponseStatusCode ]
		# (10) Requested data is missing is expected with GitHub because they do not return a response body
		Set Variable [ $errorCode[1] ; 0 // reset ]
	End If
	# Sample success response from GitHub:
	# --no response body--
	# Sample success response from Bitbucket:
	# {
	  	"build_number" : 25,
	  	"build_seconds_used" : 0,
	  	"created_on" : "2024-06-13T01:20:39.897981756Z",
	  	"creator" : 
	  	{
	  		"account_id" : "712020:9549c975-1a39-4880-b24c-<<removed>>",
	  		"account_status" : "active",
	  		"created_on" : "2024-06-13T00:30:39.257307+00:00",
	  		"display_name" : "saxml-delivery",
	  		"kind" : "repository_access_token",
	  		"links" : 
	  		{
	  			"avatar" : 
	  			{
	  				"href" : "https://avatar-management--avatars.us-west-2.prod.public.atl-paas.net/<<removed>>"
	  			}
	  		},
	  		"type" : "app_user",
	  		"uuid" : "{9d6f6dca-22a0-4777-96e7-<<removed>>}"
	  	},
	  	"duration_in_seconds" : 0,
	  	"expired" : false,
	  	"first_successful" : false,
	  	"has_variables" : false,
	  	"labels" : {},
	  	"links" : 
	  	{
	  		"self" : 
	  		{
	  			"href" : "http://bitbucket-pipelines.prod.public.atl-paas.net/rest/1.0/accounts/%7B<<removed>>%7D/repositories/%7B<<removed>>%7D/pipelines/%7B<<removed>>%7D"
	  		},
	  		"steps" : 
	  		{
	  			"href" : "http://bitbucket-pipelines.prod.public.atl-paas.net/rest/1.0/accounts/%7B<<removed>>%7D/repositories/%7<<removed>>%7D/pipelines/%7B<<removed>>%7D/steps"
	  		}
	  	},
	  	"repository" : 
	  	{
	  		"full_name" : "soliantconsulting/<<repo-name-removed>>",
	  		"links" : 
	  		{
	  			"avatar" : 
	  			{
	  				"href" : "https://bytebucket.org/ravatar/%7B<<removed>>2%7D?ts=default"
	  			},
	  			"html" : 
	  			{
	  				"href" : "https://bitbucket.org/soliantconsulting/<<repo-name-removed>>"
	  			},
	  			"self" : 
	  			{
	  				"href" : "https://api.bitbucket.org/2.0/repositories/soliantconsulting/<<repo-name-removed>>"
	  			}
	  		},
	  		"name" : "<<repo-name-removed>>",
	  		"type" : "repository",
	  		"uuid" : "{2d72112b-c2a6-4486-9b64-<<removed>>}"
	  	},
	  	"run_number" : 1,
	  	"state" : 
	  	{
	  		"name" : "PARSING",
	  		"stage" : 
	  		{
	  			"name" : "PARSING",
	  			"type" : "pipeline_state_parsing_parsing"
	  		},
	  		"type" : "pipeline_state_parsing"
	  	},
	  	"target" : 
	  	{
	  		"commit" : 
	  		{
	  			"hash" : "a40ca872ea7cc9e3de7ce878c<<removed>>",
	  			"links" : 
	  			{
	  				"html" : 
	  				{
	  					"href" : "https://bitbucket.org/soliantconsulting/<<repo-name-removed>>/commits/a40ca872ea7cc9e3de7ce878c<<removed>>"
	  				},
	  				"self" : 
	  				{
	  					"href" : "https://api.bitbucket.org/2.0/repositories/soliantconsulting/<<repo-name-removed>>/commit/a40ca872ea7cc9e3de7ce878c<<removed>>"
	  				}
	  			},
	  			"type" : "commit"
	  		},
	  		"ref_name" : "main",
	  		"ref_type" : "branch",
	  		"selector" : 
	  		{
	  			"pattern" : "pull-xml",
	  			"type" : "custom"
	  		},
	  		"type" : "pipeline_ref_target"
	  	},
	  	"trigger" : 
	  	{
	  		"name" : "MANUAL",
	  		"type" : "pipeline_trigger_manual"
	  	},
	  	"type" : "pipeline",
	  	"uuid" : "{f1f8cc0f-cd15-4594-9ca4-<<removed>>}"
	  }
End If

# Extract info from success response
If [ Collapsed: OFF ; $errorCode = 0 and not $isErrorResponseStatusCode ]
	If [ Collapsed: OFF ; $gitService = "Bitbucket" ]
		Set Variable [ $buildNumber[1] ; JSONGetElement ( $response ; "build_number" ) ]
		Set Variable [ $createdOn[1] ; JSONGetElement ( $response ; "created_on" ) ]
		Set Variable [ $repoUrl[1] ; JSONGetElement ( $response ; "repository.links.html.href" ) ]
	End If
End If

# Build error $message
If [ Collapsed: OFF ; IsEmpty ( $message ) ]
	If [ Collapsed: OFF ; $errorCode > 1 ]
		Set Variable [ $message[1] ; // We would typically use a custom function here, but we wanted this script to have as few dependencies as possible
/**
 * @SIGNATURE:
 * ErrorMessage ( errorCode )
 * 
 * @PARAMETERS:
 * errorCode	:	Number corresponding to the error code. For example, from Get ( LastError ).
 * 
 * @HISTORY:
 *     Created	:	yyyy-MMM-dd by Jeremiah Small (?) , Soliant Consulting
 * 			  	posted on http://www.briandunning.com/cf/124
 *    Modified	:	2011-08-07 by Mislav Kos, Soliant Consulting
 *    Modified	:	2017-12-16 by Mislav Kos, Soliant Consulting - now current through FileMaker 16
 *    Modified	:	2022-10-17 by Mislav Kos, Soliant Consulting - now current through FileMaker 19.5
 * 
 * @PURPOSE:
 * Return error descriptions for codes from FileMaker help text (see https://help.claris.com/en/pro-help/content/error-codes.html)
 * 
 * @RESULT:
 * Error description text.
 * 
 * @ERRORS:
 * N/A
 */

Let ( [  
		errorCode = $errorCode ; 
		errorMessage = Case (
			errorCode =   -1 ; 			"Unknown error" ; 
			errorCode =   0 ; 			"No error" ; 
			errorCode =   1 ; 			"User canceled action" ; 
			errorCode =   2 ; 			"Memory error" ; 
			errorCode =   3 ; 			"Command is unavailable (for example, wrong operating system or mode)" ; 
			errorCode =   4 ; 			"Command is unknown" ; 
			errorCode =   5 ; 			"Command is invalid (for example, a Set Field script step does not have a calculation specified)" ; 
			errorCode =   6 ; 			"File is read-only" ; 
			errorCode =   7 ; 			"Running out of memory" ; 
			errorCode =   9 ; 			"Insufficient privileges" ; 
			errorCode =   10 ; 			"Requested data is missing" ; 
			errorCode =   11 ; 			"Name is not valid" ; 
			errorCode =   12 ; 			"Name already exists" ; 
			errorCode =   13 ; 			"File or object is in use" ; 
			errorCode =   14 ; 			"Out of range" ; 
			errorCode =   15 ; 			"Can't divide by zero" ; 
			errorCode =   16 ; 			"Operation failed; request retry (for example, a user query)" ; 
			errorCode =   17 ; 			"Attempt to convert foreign character set to UTF-16 failed" ; 
			errorCode =   18 ; 			"Client must provide account information to proceed" ; 
			errorCode =   19 ; 			"String contains characters other than A-Z, a-z, 0-9 (ASCII)" ; 
			errorCode =   20 ; 			"Command/operation canceled by triggered script" ; 
			errorCode =   21 ; 			"Request not supported (for example, when creating a hard link on a file system that does not support hard links)" ; 
			errorCode =   100 ; 			"File is missing" ; 
			errorCode =   101 ; 			"Record is missing" ; 
			errorCode =   102 ; 			"Field is missing" ; 
			errorCode =   103 ; 			"Relationship is missing" ; 
			errorCode =   104 ; 			"Script is missing" ; 
			errorCode =   105 ; 			"Layout is missing" ; 
			errorCode =   106 ; 			"Table is missing" ; 
			errorCode =   107 ; 			"Index is missing" ; 
			errorCode =   108 ; 			"Value list is missing" ; 
			errorCode =   109 ; 			"Privilege set is missing" ; 
			errorCode =   110 ; 			"Related tables are missing" ; 
			errorCode =   111 ; 			"Field repetition is invalid" ; 
			errorCode =   112 ; 			"Window is missing" ; 
			errorCode =   113 ; 			"Function is missing" ; 
			errorCode =   114 ; 			"File reference is missing" ; 
			errorCode =   115 ; 			"Menu set is missing" ; 
			errorCode =   116 ; 			"Layout object is missing" ; 
			errorCode =   117 ; 			"Data source is missing" ; 
			errorCode =   118 ; 			"Theme is missing" ; 
			errorCode =   130 ; 			"Files are damaged or missing and must be reinstalled" ; 
			errorCode =   131 ; 			"Language pack files are missing" ; 
			errorCode =   200 ; 			"Record access is denied" ; 
			errorCode =   201 ; 			"Field cannot be modified" ; 
			errorCode =   202 ; 			"Field access is denied" ; 
			errorCode =   203 ; 			"No records in file to print, or password doesn't allow print access" ; 
			errorCode =   204 ; 			"No access to field(s) in sort order" ; 
			errorCode =   205 ; 			"User does not have access privileges to create new records; import will overwrite existing data" ; 
			errorCode =   206 ; 			"User does not have password change privileges, or file is not modifiable" ; 
			errorCode =   207 ; 			"User does not have privileges to change database schema, or file is not modifiable" ; 
			errorCode =   208 ; 			"Password does not contain enough characters" ; 
			errorCode =   209 ; 			"New password must be different from existing one" ; 
			errorCode =   210 ; 			"User account is inactive" ; 
			errorCode =   211 ; 			"Password has expired" ; 
			errorCode =   212 ; 			"Invalid user account or password" ; 
			errorCode =   214 ; 			"Too many login attempts" ; 
