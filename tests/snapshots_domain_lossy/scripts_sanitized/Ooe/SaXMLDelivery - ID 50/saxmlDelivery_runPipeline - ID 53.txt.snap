			errorCode =   400 ; 			"Find criteria are empty" ; 
			errorCode =   401 ; 			"No records match the request" ; 
			errorCode =   402 ; 			"Selected field is not a match field for a lookup" ; 
			errorCode =   404 ; 			"Sort order is invalid" ; 
