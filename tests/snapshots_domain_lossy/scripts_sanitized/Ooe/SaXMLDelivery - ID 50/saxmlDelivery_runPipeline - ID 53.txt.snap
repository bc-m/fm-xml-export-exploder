	"(" & errorCode & ") " & errorMessage 
	
) ]
	Else If [ Collapsed: OFF ; $isErrorResponseStatusCode ]
		Set Variable [ $errorCode[1] ; 999 & $responseStatusCode ]
		Set Variable [ $responseStatusMessage[1] ; "(" & $responseStatusCode & ") " & Let ( 

	statusCode = $responseStatusCode ; 


	// We would typically use a custom function here, but we wanted this script to have as few dependencies as possible
	// Signature:
	// GetHttpResponseStatusMessage ( statusCode )
	
	// Purpose:
	// Return HTTP response status code message
	
	// Parameters:
	// statusCode: the http response status code for which we want to return the message
	
	// Result:
	// HTTP response status code message
	
	// Dependencies:
	// None
	
	// History:
	// 2023-05-03 Mislav Kos <mkos@soliantconsulting.com>: Created custom function.
	
	Case ( 
	
		statusCode = 100 ; "Continue" ; 
		statusCode = 101 ; "Switching Protocols" ; 
		statusCode = 102 ; "Processing (WebDAV; RFC 2518)" ; 
		statusCode = 103 ; "Early Hints (RFC 8297)" ; 
		statusCode = 200 ; "OK" ; 
		statusCode = 201 ; "Created" ; 
		statusCode = 202 ; "Accepted" ; 
		statusCode = 203 ; "Non-Authoritative Information (since HTTP/1.1)" ; 
		statusCode = 204 ; "No Content" ; 
		statusCode = 205 ; "Reset Content" ; 
		statusCode = 206 ; "Partial Content (RFC 7233)" ; 
		statusCode = 207 ; "Multi-Status (WebDAV; RFC 4918)" ; 
		statusCode = 208 ; "Already Reported (WebDAV; RFC 5842)" ; 
		statusCode = 218 ; "This is fine (Apache Web Server)" ; 
		statusCode = 226 ; "IM Used (RFC 3229)" ; 
		statusCode = 300 ; "Multiple Choices" ; 
		statusCode = 301 ; "Moved Permanently" ; 
		statusCode = 302 ; "Found (Previously 'Moved temporarily')" ; 
		statusCode = 303 ; "See Other (since HTTP/1.1)" ; 
		statusCode = 304 ; "Not Modified (RFC 7232)" ; 
		statusCode = 305 ; "Use Proxy (since HTTP/1.1)" ; 
		statusCode = 306 ; "Switch Proxy" ; 
		statusCode = 307 ; "Temporary Redirect (since HTTP/1.1)" ; 
		statusCode = 308 ; "Permanent Redirect (RFC 7538)" ; 
		statusCode = 400 ; "Bad Request" ; 
		statusCode = 401 ; "Unauthorized (RFC 7235)" ; 
		statusCode = 402 ; "Payment Required" ; 
		statusCode = 403 ; "Forbidden" ; 
		statusCode = 404 ; "Not Found" ; 
		statusCode = 405 ; "Method Not Allowed" ; 
		statusCode = 406 ; "Not Acceptable" ; 
		statusCode = 407 ; "Proxy Authentication Required (RFC 7235)" ; 
		statusCode = 408 ; "Request Timeout" ; 
		statusCode = 409 ; "Conflict" ; 
		statusCode = 410 ; "Gone" ; 
		statusCode = 411 ; "Length Required" ; 
		statusCode = 412 ; "Precondition Failed (RFC 7232)" ; 
		statusCode = 413 ; "Payload Too Large (RFC 7231)" ; 
		statusCode = 414 ; "URI Too Long (RFC 7231)" ; 
		statusCode = 415 ; "Unsupported Media Type" ; 
		statusCode = 416 ; "Range Not Satisfiable (RFC 7233)" ; 
		statusCode = 417 ; "Expectation Failed" ; 
		statusCode = 418 ; "I'm a teapot (RFC 2324, RFC 7168)" ; 
		statusCode = 419 ; "Page Expired (Laravel Framework)" ; 
		statusCode = 420 ; "Method Failure (Spring Framework) or Enhance Your Calm (Twitter)" ; 
		statusCode = 421 ; "Misdirected Request (RFC 7540)" ; 
		statusCode = 422 ; "Unprocessable Entity (WebDAV; RFC 4918)" ; 
		statusCode = 423 ; "Locked (WebDAV; RFC 4918)" ; 
		statusCode = 424 ; "Failed Dependency (WebDAV; RFC 4918)" ; 
		statusCode = 426 ; "Upgrade Required" ; 
		statusCode = 428 ; "Precondition Required (RFC 6585)" ; 
		statusCode = 429 ; "Too Many Requests (RFC 6585)" ; 
		statusCode = 431 ; "Request Header Fields Too Large (RFC 6585)" ; 
		statusCode = 440 ; "Login Time-out" ; 
		statusCode = 444 ; "No Response" ; 
		statusCode = 449 ; "Retry With or Client Closed Request" ; 
		statusCode = 450 ; "Blocked by Windows Parental Controls (Microsoft)" ; 
		statusCode = 451 ; "Unavailable For Legal Reasons (RFC 7725)" ; 
		statusCode = 494 ; "Request header too large" ; 
		statusCode = 495 ; "SSL Certificate Error" ; 
		statusCode = 496 ; "SSL Certificate Required" ; 
		statusCode = 497 ; "HTTP Request Sent to HTTPS Port" ; 
		statusCode = 498 ; "Invalid Token (Esri)" ; 
		statusCode = 499 ; "Token Required (Esri)" ; 
		statusCode = 500 ; "Internal Server Error" ; 
		statusCode = 501 ; "Not Implemented" ; 
		statusCode = 502 ; "Bad Gateway" ; 
		statusCode = 503 ; "Service Unavailable" ; 
		statusCode = 504 ; "Gateway Timeout" ; 
		statusCode = 505 ; "HTTP Version Not Supported" ; 
		statusCode = 506 ; "Variant Also Negotiates (RFC 2295)" ; 
		statusCode = 507 ; "Insufficient Storage (WebDAV; RFC 4918)" ; 
		statusCode = 508 ; "Loop Detected (WebDAV; RFC 5842)" ; 
		statusCode = 509 ; "Bandwidth Limit Exceeded (Apache Web Server/cPanel)" ; 
		statusCode = 510 ; "Not Extended (RFC 2774)" ; 
		statusCode = 511 ; "Network Authentication Required (RFC 6585)" ; 
		statusCode = 520 ; "Unknown Error" ; 
		statusCode = 521 ; "Web Server Is Down" ; 
		statusCode = 522 ; "Connection Timed Out" ; 
		statusCode = 523 ; "Origin Is Unreachable" ; 
		statusCode = 524 ; "A Timeout Occurred" ; 
		statusCode = 525 ; "SSL Handshake Failed" ; 
		statusCode = 526 ; "Invalid SSL Certificate" ; 
		statusCode = 527 ; "Railgun Error" ; 
		statusCode = 530 ; "Site is frozen or Origin DNS Error" ; 
		statusCode = 598 ; "(Informal convention) Network read timeout error" ; 	
	)

) ]
		Set Variable [ $message[1] ; $responseStatusMessage & If ( 
	Left ( JSONGetElement ( $response ; "doesnotmatterwhatishere" ) ; 3 ) ≠ "? *" ; 
	". " & JSONGetElement ( $response ; "error.message" )
) ]
	End If
End If

# Display $message
If [ Collapsed: OFF ; not $_silent 
and PatternCount ( Get ( ApplicationVersion ) ; "Data API Engine" ) = 0 
and PatternCount ( Get ( ApplicationVersion ) ; "Server" ) = 0 ]
	If [ Collapsed: OFF ; $errorCode = 0 ]
		If [ Collapsed: OFF ; $gitService = "Bitbucket" ]
			Set Variable [ $message[1] ; "The " & Quote ( $repoName ) & " pipeline is running build # " & $buildNumber & ". View in browser?" ]
			Show Custom Dialog [ Message: $message ; Default Button: "Dismiss" ; Button 2: "View" ]
			If [ Collapsed: OFF ; Get ( LastMessageChoice ) = 2 ]
				Set Variable [ $pipelineBuildUrl[1] ; $repoUrl & "/pipelines/results/" & $buildNumber ]
				Open URL [ In external browser: OFF ; With dialog: OFF ; ⚠️ PARAMETER "URL" NOT PARSED ⚠️ ]
			End If
		Else [ Collapsed: OFF ; Collapsed: OFF ]
			# GitHub
			Show Custom Dialog [ Message: "The " & Quote ( $repoName ) & " pipeline is running." ; Default Button: "OK" ]
		End If
	Else If [ Collapsed: OFF ; not IsEmpty ( $message ) ]
		Show Custom Dialog [ Title: "Error" ; Message: $message ; Default Button: "OK" ]
	End If
End If

# Build $data
If [ Collapsed: OFF ; $errorCode = 0 ]
	If [ Collapsed: OFF ; $gitService = "Bitbucket" ]
		Set Variable [ $data[1] ; JSONSetElement ( $data 
	; [ "buildNumber" ; $buildNumber ; JSONString ] 
	; [ "createdOn" ; $createdOn ; JSONString ] 
	; [ "pipelineBuildUrl" ; $pipelineBuildUrl ; JSONString ] 
	; [ "repoUrl" ; $repoUrl ; JSONString ] 
) ]
	End If
End If

# ====================================================================================================
# END
# ====================================================================================================

If [ Collapsed: OFF ; $parentScriptErrorCaptureState ]
	Set Error Capture [ OFF ]
Else [ Collapsed: OFF ; Collapsed: OFF ]
	Set Error Capture [ OFF ]
End If

Exit Script [ $result ]
